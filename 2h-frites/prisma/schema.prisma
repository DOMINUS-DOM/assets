generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// MULTI-TENANT — Organization is the tenant boundary
// ═══════════════════════════════════════

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  customDomain String?  @unique
  brandingJson String   @default("{}")        // colors, logo, texts
  modulesJson  String   @default("{}")        // enabled features (synced with addons)
  active       Boolean  @default(true)
  onboarded    Boolean  @default(false)          // flipped true once a tenant passes through the welcome wizard (or skips it)
  createdAt    DateTime @default(now())

  // ─── Subscription & Billing ───
  subscriptionStatus   String    @default("trial")  // trial | active | past_due | cancelled | expired
  planType             String?                       // starter | pro | custom (null during trial)
  addons               String    @default("[]")      // JSON array: ["web", "kiosk", "kds", "analytics", "multiusers"]
  trialEndsAt          DateTime?
  cancelAt             DateTime?                     // set when user schedules cancel-at-period-end via Stripe portal
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?

  locations     Location[]
  users         User[]
  orderChannels OrderChannel[]
}

// ═══════════════════════════════════════
// MULTI-LOCATION / FRANCHISE
// ═══════════════════════════════════════

model Location {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String   // "2H Frites — La Louvière Centre"
  slug           String   @unique
  address        String
  city           String
  postalCode     String
  phone          String
  email          String
  lat            Float?
  lng            Float?
  active         Boolean  @default(true)
  settingsJson   String   @default("{}") // hours, zones, fees as JSON
  createdAt      DateTime @default(now())

  users         User[]
  employees     Employee[]
  orders        Order[]
  drivers       Driver[]
  ingredients   Ingredient[]
  shifts        Shift[]
  tasks         Task[]
  notifications Notification[]
  auditLogs     AuditLog[]
  payPeriods    PayPeriod[]

  // Digital Signage
  signageScreens   SignageScreen[]
  signageContents  SignageContent[]
  signagePlaylists SignagePlaylist[]
  signageMedia     SignageMedia[]

  // Menu catalog
  menuCategories    MenuCategory[]
  modifierGroups    ModifierGroup[]

  // New modules
  tables            FloorTable[]
  reservations      Reservation[]
  purchaseInvoices  PurchaseInvoice[]
}

// ═══════════════════════════════════════
// AUTH — Extended for franchise roles
// ═══════════════════════════════════════

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  phone        String
  // Roles: platform_super_admin, franchisor_admin, franchisee_owner, location_manager, employe, livreur, client
  role               String    @default("client")
  active             Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  tempPasswordExpiresAt DateTime?                   // set on employee invite; login refused if elapsed
  avatarUrl       String?
  permissionsJson String    @default("{}")
  driverId        String?
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  createdAt    DateTime  @default(now())

  employee  Employee?
  orders    Order[]
  auditLogs AuditLog[]
  passwordResetTokens PasswordResetToken[]
}

// One-time tokens for self-service password reset.
// tokenHash = sha256(rawToken) so a DB leak can't be used to reset passwords.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ═══════════════════════════════════════
// STAFF / HR
// ═══════════════════════════════════════

model Employee {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id])
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  name         String
  phone        String
  email        String
  position     String
  contractType String
  hourlyRate   Float
  hireDate     String
  active       Boolean   @default(true)
  notes        String    @default("")

  shifts        Shift[]
  timeEntries   TimeEntry[]
  leaveRequests LeaveRequest[]
  tasks         Task[]
  payslips      Payslip[]
}

model Shift {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  date       String
  startTime  String
  endTime    String
  position   String
  notes      String    @default("")

  @@index([employeeId])
  @@index([locationId])
}

model TimeEntry {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  date        String
  clockIn     DateTime
  clockOut    DateTime?
  hoursWorked Float?

  @@index([employeeId])
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String
  startDate  String
  endDate    String
  reason     String   @default("")
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@index([employeeId])
}

model Task {
  id                 String    @id @default(cuid())
  employeeId         String?
  employee           Employee? @relation(fields: [employeeId], references: [id])
  locationId         String?
  location           Location? @relation(fields: [locationId], references: [id])
  title              String
  description        String    @default("")
  date               String
  dueTime            String?   // HH:mm
  completed          Boolean   @default(false)
  completedAt        DateTime?
  category           String    // prep, cleaning, restock, other
  priority           String    @default("medium") // low, medium, high, urgent
  photoUrl           String?   // reference photo from admin
  completionPhotoUrl String?   // proof photo from employee
  requiresPhoto      Boolean   @default(false)
  createdAt          DateTime  @default(now())

  @@index([employeeId])
  @@index([locationId])
}

// ═══════════════════════════════════════
// MENU CATALOG — Relational product engine
// ═══════════════════════════════════════

model MenuCategory {
  id         String      @id @default(cuid())
  locationId String?
  location   Location?   @relation(fields: [locationId], references: [id])
  parentId   String?
  parent     MenuCategory? @relation("SubCategories", fields: [parentId], references: [id])
  children   MenuCategory[] @relation("SubCategories")
  slug       String
  nameKey    String
  icon       String      @default("🍽️")
  imageUrl   String?     // Cloudinary public_id — preferred over icon in menu when set
  sortOrder  Int         @default(0)
  active     Boolean     @default(true)
  builder    Boolean     @default(false)
  note       String?     // "perIngredient" etc.
  flatPrice  Float?      // if all items share one price

  items MenuProduct[]

  @@unique([locationId, slug])
  @@index([locationId])
  @@index([parentId])
}

model MenuProduct {
  id          String       @id @default(cuid())
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  nameKey     String?      // i18n key
  descKey     String?      // i18n description key
  price       Float?
  active      Boolean      @default(true)
  available   Boolean      @default(true)    // false = rupture de stock temporaire
  visibleOnPos   Boolean   @default(true)
  visibleOnWeb   Boolean   @default(true)
  visibleOnKiosk Boolean   @default(true)
  sortOrder   Int          @default(0)
  tags        String       @default("[]")   // JSON: ["popular","spicy"]
  allergens   String       @default("[]")   // JSON: [1,3,7]
  subcategory String?
  priceLabel  String?
  imageUrl    String?

  sizes          ProductSize[]
  modifierLinks  ProductModifierGroup[]
  builderConfig  BuilderConfig?
  orderItems     OrderItem[]
  recipe         Recipe?         @relation("ProductRecipe")

  @@index([categoryId])
}

model ProductSize {
  id        String      @id @default(cuid())
  productId String
  product   MenuProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  sizeKey   String      // "petit", "moyen", "grand"
  price     Float
  sortOrder Int         @default(0)

  @@unique([productId, sizeKey])
}

model ModifierGroup {
  id         String     @id @default(cuid())
  locationId String?
  location   Location?  @relation(fields: [locationId], references: [id])
  name       String     // "Sauces", "Supplements", "Boissons"
  nameKey    String?    // i18n
  minSelect  Int        @default(0)
  maxSelect  Int        @default(1)
  required   Boolean    @default(false)
  sortOrder  Int        @default(0)

  modifiers    Modifier[]
  productLinks ProductModifierGroup[]

  @@index([locationId])
}

model Modifier {
  id        String        @id @default(cuid())
  groupId   String
  group     ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name      String
  nameKey   String?
  price     Float         @default(0)
  active    Boolean       @default(true)
  sortOrder Int           @default(0)

  @@index([groupId])
}

model ProductModifierGroup {
  id        String        @id @default(cuid())
  productId String
  product   MenuProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  groupId   String
  group     ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sortOrder Int           @default(0)

  @@unique([productId, groupId])
}

model BuilderConfig {
  id        String      @id @default(cuid())
  productId String      @unique
  product   MenuProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  basePrice Float
  steps     String      // JSON: [{key, label, groupId, maxSelect, type, options}]
  options   String?     // JSON: extra config (salt toggle, etc.)
}

// ═══════════════════════════════════════
// ORDERS — with locationId
// ═══════════════════════════════════════

model Order {
  id             String    @id @default(cuid())
  orderNumber    String    @unique
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
  type           String
  status         String    @default("received")
  customerName   String
  customerPhone  String
  customerEmail  String?
  deliveryStreet String?
  deliveryCity   String?
  deliveryPostal String?
  deliveryNotes  String?
  pickupTime     String?
  paymentMethod  String
  paymentStatus  String    @default("pending")
  stripePaymentId String?  // Stripe payment intent ID
  channel         String   @default("website") // website, uber_eats, deliveroo, phone
  total          Float
  driverId       String?
  tableId        String?
  table          FloorTable? @relation(fields: [tableId], references: [id])
  userId         String?
  user           User?     @relation(fields: [userId], references: [id])
  createdAt      DateTime  @default(now())

  items         OrderItem[]
  statusHistory StatusEntry[]
  transactions  Transaction[]
  invoice       Invoice?

  @@index([locationId])
  @@index([createdAt])
  @@index([status])
}

model OrderItem {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id])
  menuItemId String
  productId  String?
  product    MenuProduct? @relation(fields: [productId], references: [id])
  name       String
  price      Float
  quantity   Int
  sizeKey    String?
  categoryId String
  extras     String       @default("[]") // JSON: [{name, price}]
  notes      String?      // "sans sel", "bien cuit"
  discount   Float        @default(0)    // discount amount on this line

  @@index([orderId])
}

model StatusEntry {
  id      String   @id @default(cuid())
  orderId String
  order   Order    @relation(fields: [orderId], references: [id])
  status  String
  at      DateTime @default(now())

  @@index([orderId])
}

// ═══════════════════════════════════════
// DRIVERS — with locationId
// ═══════════════════════════════════════

model Driver {
  id              String    @id @default(cuid())
  userId          String?
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  name            String
  phone           String
  email           String
  active          Boolean   @default(true)
  contractType    String
  zone            String
  notes           String    @default("")
  ratePerDelivery Float
  bonusRate       Float     @default(0)
  // GPS tracking
  lastLat         Float?
  lastLng         Float?
  lastLocationAt  DateTime?
}

model DriverApplication {
  id           String   @id @default(cuid())
  name         String
  phone        String
  email        String
  city         String
  transport    String
  availability String
  status       String   @default("new")
  createdAt    DateTime @default(now())
}

// ═══════════════════════════════════════
// PAYMENTS — Stripe-ready
// ═══════════════════════════════════════

model Transaction {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  amount          Float
  method          String   // cash, card, online, bancontact
  status          String   @default("pending") // pending, completed, failed, refunded
  reference       String?  // Stripe/Mollie payment ID
  stripeSessionId String?
  createdAt       DateTime @default(now())
}

model Invoice {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])
  invoiceNumber   String?  @unique
  customerName    String
  customerPhone   String
  customerAddress String?
  subtotal        Float
  totalVat        Float
  deliveryFee     Float    @default(0)
  grandTotal      Float
  vatNumber       String
  businessName    String
  businessAddress String
  linesJson       String
  createdAt       DateTime @default(now())
}

// ═══════════════════════════════════════
// INVENTORY — with locationId
// ═══════════════════════════════════════

model Ingredient {
  id           String    @id @default(cuid())
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  name         String
  unit         String
  currentStock Float
  minStock     Float
  costPerUnit  Float
  supplierId   String?
  expiryDate   String?
  category     String

  movements    StockMovement[]
  recipeItems  RecipeItem[]
  invoiceLines PurchaseInvoiceLine[]
}

model Supplier {
  id    String @id @default(cuid())
  name  String
  phone String
  email String
  notes String @default("")

  purchaseInvoices PurchaseInvoice[]
}

model StockMovement {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  type         String
  quantity     Float
  note         String     @default("")
  date         String

  @@index([ingredientId])
}

// ═══════════════════════════════════════
// PAYROLL — with locationId
// ═══════════════════════════════════════

model PayPeriod {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  label      String
  startDate  String
  endDate    String
  status     String    @default("draft")

  payslips Payslip[]
}

model Payslip {
  id               String    @id @default(cuid())
  periodId         String
  period           PayPeriod @relation(fields: [periodId], references: [id])
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id])
  employeeName     String
  regularHours     Float
  overtimeHours    Float
  hourlyRate       Float
  overtimeRate     Float
  grossRegular     Float
  grossOvertime    Float
  grossTotal       Float
  deductions       Float
  netTotal         Float
  bonus            Float     @default(0)
  deliveryCount    Int?
  deliveryEarnings Float?
  status           String    @default("draft")
  createdAt        DateTime  @default(now())
}

// ═══════════════════════════════════════
// NOTIFICATIONS — with locationId
// ═══════════════════════════════════════

model Notification {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  type       String
  title      String
  message    String
  read       Boolean   @default(false)
  link       String?
  createdAt  DateTime  @default(now())
}

// ═══════════════════════════════════════
// SETTINGS (global + per-location)
// ═══════════════════════════════════════

model Setting {
  key   String @id
  value String
}

// ═══════════════════════════════════════
// AUDIT TRAIL — tracks all changes
// ═══════════════════════════════════════

model AuditLog {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  action     String    // create, update, delete
  entity     String    // Order, Employee, MenuItem, etc.
  entityId   String
  changes    String    @default("{}") // JSON of old → new values
  ip         String?
  createdAt  DateTime  @default(now())
}

// ═══════════════════════════════════════
// REVIEWS
// ═══════════════════════════════════════

model Review {
  id           String   @id @default(cuid())
  orderId      String
  customerName String
  customerPhone String
  rating       Int      // 1-5
  comment      String   @default("")
  reply        String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ═══════════════════════════════════════
// REFERRALS
// ═══════════════════════════════════════

model Referral {
  id            String    @id @default(cuid())
  referrerPhone String
  referrerName  String
  code          String    @unique
  usedBy        String?
  usedAt        DateTime?
  rewardGiven   Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

// ═══════════════════════════════════════
// CRM & LOYALTY
// ═══════════════════════════════════════

model Customer {
  id             String    @id @default(cuid())
  phone          String    @unique
  name           String
  email          String?
  address        String?
  notes          String    @default("")
  segment        String    @default("new") // new, regular, vip, inactive
  loyaltyPoints  Int       @default(0)
  lifetimePoints Int       @default(0)
  totalOrders    Int       @default(0)
  totalSpent     Float     @default(0)
  lastOrderDate  DateTime?
  createdAt      DateTime  @default(now())

  loyaltyTransactions LoyaltyTransaction[]

  @@index([phone])
  @@index([segment])
}

model LoyaltyTransaction {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  type       String   // earn, redeem, bonus, expire
  points     Int      // positive for earn, negative for redeem
  reason     String   // order_ORD-123, reward_free_frites, referral_bonus, etc.
  orderId    String?
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model LoyaltyReward {
  id          String  @id @default(cuid())
  name        String  // "Frites gratuites", "Sauce offerte"
  description String  @default("")
  pointsCost  Int     // how many points to redeem
  discountType String @default("item") // item, amount, percentage
  discountValue Float @default(0)     // €5, 10%, etc.
  active      Boolean @default(true)
  imageUrl    String?
  timesRedeemed Int   @default(0)

  @@index([active])
}

// ═══════════════════════════════════════
// ORDER CHANNELS (3rd-party platforms)
// ═══════════════════════════════════════

model OrderChannel {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String  // uber_eats, deliveroo, just_eat, website, phone
  active         Boolean @default(true)
  apiKey         String?
  webhookUrl     String?
  commission     Float   @default(0)

  @@index([organizationId])
}

// ═══════════════════════════════════════
// DIGITAL SIGNAGE — Multi-site display system
// ═══════════════════════════════════════

model SignageScreen {
  id          String    @id @default(cuid())
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id])
  name        String    // "Écran comptoir 1"
  orientation String    @default("landscape") // landscape | portrait
  resolution  String    @default("1920x1080")
  status      String    @default("draft") // draft | active | offline
  code        String    @unique // 8-char unique code for player connection
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  schedules SignageSchedule[]
}

model SignageContent {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])
  name        String   // "Menu du midi", "Promo été"
  type        String   // menu | text | image | video | mixed
  duration    Int      @default(10) // seconds
  configJson  String   @default("{}") // type-specific config as JSON
  status      String   @default("draft") // draft | published
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  playlistItems SignagePlaylistItem[]
}

model SignagePlaylist {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  name       String   // "Playlist matin", "Soirée"
  loop       Boolean  @default(true)
  status     String   @default("draft") // draft | published
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items     SignagePlaylistItem[]
  schedules SignageSchedule[]
}

model SignagePlaylistItem {
  id               String          @id @default(cuid())
  playlistId       String
  playlist         SignagePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  contentId        String
  content          SignageContent  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  order            Int
  durationOverride Int?            // null = use content.duration

  @@unique([playlistId, order])
}

model SignageSchedule {
  id         String          @id @default(cuid())
  screenId   String
  screen     SignageScreen   @relation(fields: [screenId], references: [id], onDelete: Cascade)
  playlistId String
  playlist   SignagePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  daysOfWeek String          @default("0,1,2,3,4,5,6") // comma-separated day numbers
  startTime  String          @default("00:00") // HH:mm
  endTime    String          @default("23:59")
  startDate  String?         // YYYY-MM-DD, null = no start limit
  endDate    String?
  priority   Int             @default(0) // higher = takes precedence
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
}

model SignageMedia {
  id           String   @id @default(cuid())
  locationId   String
  location     Location @relation(fields: [locationId], references: [id])
  name         String   // original filename or user-given name
  type         String   // image | video
  url          String   // Cloudinary URL
  thumbnailUrl String?  // Cloudinary thumbnail (for videos)
  publicId     String   // Cloudinary public_id for deletion
  format       String   // jpg, png, mp4, etc.
  width        Int?
  height       Int?
  bytes        Int?     // file size in bytes
  duration     Float?   // video duration in seconds
  folder       String   @default("") // user folder/tag
  createdAt    DateTime @default(now())
}

// ═══════════════════════════════════════
// TABLES — Floor plan (DB-backed)
// ═══════════════════════════════════════

model FloorTable {
  id         String    @id @default(cuid())
  locationId String
  location   Location  @relation(fields: [locationId], references: [id])
  number     Int
  capacity   Int       @default(4)
  zone       String    @default("main") // main, terrace, vip
  status     String    @default("free") // free, occupied, reserved, cleaning
  x          Float?
  y          Float?
  active     Boolean   @default(true)

  orders              Order[]
  reservationTables   ReservationTable[]

  @@index([locationId])
}

// ═══════════════════════════════════════
// RESERVATIONS
// ═══════════════════════════════════════

model Reservation {
  id            String    @id @default(cuid())
  locationId    String
  location      Location  @relation(fields: [locationId], references: [id])
  date          String    // YYYY-MM-DD
  timeSlot      String    // HH:mm
  endTime       String    // HH:mm
  duration      Int       @default(90) // minutes
  partySize     Int
  customerName  String
  customerPhone String
  customerEmail String?
  status        String    @default("pending") // pending, confirmed, seated, completed, cancelled, no_show
  notes         String    @default("")
  source        String    @default("admin") // admin, online, phone
  createdAt     DateTime  @default(now())

  tables ReservationTable[]

  @@index([locationId])
  @@index([date])
}

model ReservationTable {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  tableId       String
  table         FloorTable  @relation(fields: [tableId], references: [id])

  @@unique([reservationId, tableId])
}

// ═══════════════════════════════════════
// PURCHASE INVOICES — Supplier billing
// ═══════════════════════════════════════

model PurchaseInvoice {
  id            String    @id @default(cuid())
  locationId    String?
  location      Location? @relation(fields: [locationId], references: [id])
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  invoiceNumber String?
  invoiceDate   String    // YYYY-MM-DD
  dueDate       String?
  subtotal      Float
  totalVat      Float
  grandTotal    Float
  status        String    @default("draft") // draft, validated, paid
  imageUrl      String?   // Cloudinary photo of paper invoice
  aiExtracted   Boolean   @default(false)
  notes         String    @default("")
  createdAt     DateTime  @default(now())

  lines PurchaseInvoiceLine[]

  @@index([locationId])
  @@index([supplierId])
  @@index([invoiceDate])
}

model PurchaseInvoiceLine {
  id           String           @id @default(cuid())
  invoiceId    String
  invoice      PurchaseInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description  String
  ingredientId String?
  ingredient   Ingredient?      @relation(fields: [ingredientId], references: [id])
  quantity     Float
  unitPrice    Float
  vatRate      Float            @default(0.06)
  total        Float

  @@index([invoiceId])
}

// ═══════════════════════════════════════
// RECIPES — Cost tracking per menu item
// ═══════════════════════════════════════

model Recipe {
  id         String       @id @default(cuid())
  menuItemId String       @unique // legacy: references menu item ID from JSON menu
  productId  String?      @unique
  product    MenuProduct? @relation("ProductRecipe", fields: [productId], references: [id])
  name       String
  prepTime   Int?         // minutes
  notes      String       @default("")

  items RecipeItem[]
}

model RecipeItem {
  id           String     @id @default(cuid())
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  unit         String

  @@index([recipeId])
  @@index([ingredientId])
}
