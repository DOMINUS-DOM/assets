generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// MULTI-LOCATION / FRANCHISE
// ═══════════════════════════════════════

model Location {
  id          String   @id @default(cuid())
  name        String   // "2H Frites — La Louvière Centre"
  slug        String   @unique
  address     String
  city        String
  postalCode  String
  phone       String
  email       String
  lat         Float?
  lng         Float?
  active      Boolean  @default(true)
  settingsJson String  @default("{}") // hours, zones, fees as JSON
  createdAt   DateTime @default(now())

  users         User[]
  employees     Employee[]
  orders        Order[]
  drivers       Driver[]
  ingredients   Ingredient[]
  shifts        Shift[]
  tasks         Task[]
  notifications Notification[]
  auditLogs     AuditLog[]
  payPeriods    PayPeriod[]

  // Digital Signage
  signageScreens   SignageScreen[]
  signageContents  SignageContent[]
  signagePlaylists SignagePlaylist[]
  signageMedia     SignageMedia[]
}

// ═══════════════════════════════════════
// AUTH — Extended for franchise roles
// ═══════════════════════════════════════

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  phone        String
  // Roles: franchisor_admin, franchisee_owner, location_manager, employe, livreur, client
  role         String    @default("client")
  active          Boolean   @default(true)
  avatarUrl       String?
  permissionsJson String    @default("{}")
  driverId        String?
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  createdAt    DateTime  @default(now())

  employee  Employee?
  orders    Order[]
  auditLogs AuditLog[]
}

// ═══════════════════════════════════════
// STAFF / HR
// ═══════════════════════════════════════

model Employee {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id])
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  name         String
  phone        String
  email        String
  position     String
  contractType String
  hourlyRate   Float
  hireDate     String
  active       Boolean   @default(true)
  notes        String    @default("")

  shifts        Shift[]
  timeEntries   TimeEntry[]
  leaveRequests LeaveRequest[]
  tasks         Task[]
  payslips      Payslip[]
}

model Shift {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  date       String
  startTime  String
  endTime    String
  position   String
  notes      String    @default("")

  @@index([employeeId])
  @@index([locationId])
}

model TimeEntry {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  date        String
  clockIn     DateTime
  clockOut    DateTime?
  hoursWorked Float?

  @@index([employeeId])
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String
  startDate  String
  endDate    String
  reason     String   @default("")
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@index([employeeId])
}

model Task {
  id                 String    @id @default(cuid())
  employeeId         String?
  employee           Employee? @relation(fields: [employeeId], references: [id])
  locationId         String?
  location           Location? @relation(fields: [locationId], references: [id])
  title              String
  description        String    @default("")
  date               String
  dueTime            String?   // HH:mm
  completed          Boolean   @default(false)
  completedAt        DateTime?
  category           String    // prep, cleaning, restock, other
  priority           String    @default("medium") // low, medium, high, urgent
  photoUrl           String?   // reference photo from admin
  completionPhotoUrl String?   // proof photo from employee
  requiresPhoto      Boolean   @default(false)
  createdAt          DateTime  @default(now())

  @@index([employeeId])
  @@index([locationId])
}

// ═══════════════════════════════════════
// ORDERS — with locationId
// ═══════════════════════════════════════

model Order {
  id             String    @id @default(cuid())
  orderNumber    String    @unique
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
  type           String
  status         String    @default("received")
  customerName   String
  customerPhone  String
  customerEmail  String?
  deliveryStreet String?
  deliveryCity   String?
  deliveryPostal String?
  deliveryNotes  String?
  pickupTime     String?
  paymentMethod  String
  paymentStatus  String    @default("pending")
  stripePaymentId String?  // Stripe payment intent ID
  channel         String   @default("website") // website, uber_eats, deliveroo, phone
  total          Float
  driverId       String?
  userId         String?
  user           User?     @relation(fields: [userId], references: [id])
  createdAt      DateTime  @default(now())

  items         OrderItem[]
  statusHistory StatusEntry[]
  transactions  Transaction[]
  invoice       Invoice?

  @@index([locationId])
  @@index([createdAt])
  @@index([status])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  order      Order  @relation(fields: [orderId], references: [id])
  menuItemId String
  name       String
  price      Float
  quantity   Int
  sizeKey    String?
  categoryId String

  @@index([orderId])
}

model StatusEntry {
  id      String   @id @default(cuid())
  orderId String
  order   Order    @relation(fields: [orderId], references: [id])
  status  String
  at      DateTime @default(now())

  @@index([orderId])
}

// ═══════════════════════════════════════
// DRIVERS — with locationId
// ═══════════════════════════════════════

model Driver {
  id              String    @id @default(cuid())
  userId          String?
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  name            String
  phone           String
  email           String
  active          Boolean   @default(true)
  contractType    String
  zone            String
  notes           String    @default("")
  ratePerDelivery Float
  bonusRate       Float     @default(0)
  // GPS tracking
  lastLat         Float?
  lastLng         Float?
  lastLocationAt  DateTime?
}

model DriverApplication {
  id           String   @id @default(cuid())
  name         String
  phone        String
  email        String
  city         String
  transport    String
  availability String
  status       String   @default("new")
  createdAt    DateTime @default(now())
}

// ═══════════════════════════════════════
// PAYMENTS — Stripe-ready
// ═══════════════════════════════════════

model Transaction {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  amount          Float
  method          String   // cash, card, online, bancontact
  status          String   @default("pending") // pending, completed, failed, refunded
  reference       String?  // Stripe/Mollie payment ID
  stripeSessionId String?
  createdAt       DateTime @default(now())
}

model Invoice {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])
  invoiceNumber   String?  @unique
  customerName    String
  customerPhone   String
  customerAddress String?
  subtotal        Float
  totalVat        Float
  deliveryFee     Float    @default(0)
  grandTotal      Float
  vatNumber       String
  businessName    String
  businessAddress String
  linesJson       String
  createdAt       DateTime @default(now())
}

// ═══════════════════════════════════════
// INVENTORY — with locationId
// ═══════════════════════════════════════

model Ingredient {
  id           String    @id @default(cuid())
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  name         String
  unit         String
  currentStock Float
  minStock     Float
  costPerUnit  Float
  supplierId   String?
  expiryDate   String?
  category     String

  movements StockMovement[]
}

model Supplier {
  id    String @id @default(cuid())
  name  String
  phone String
  email String
  notes String @default("")
}

model StockMovement {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  type         String
  quantity     Float
  note         String     @default("")
  date         String

  @@index([ingredientId])
}

// ═══════════════════════════════════════
// PAYROLL — with locationId
// ═══════════════════════════════════════

model PayPeriod {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  label      String
  startDate  String
  endDate    String
  status     String    @default("draft")

  payslips Payslip[]
}

model Payslip {
  id               String    @id @default(cuid())
  periodId         String
  period           PayPeriod @relation(fields: [periodId], references: [id])
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id])
  employeeName     String
  regularHours     Float
  overtimeHours    Float
  hourlyRate       Float
  overtimeRate     Float
  grossRegular     Float
  grossOvertime    Float
  grossTotal       Float
  deductions       Float
  netTotal         Float
  bonus            Float     @default(0)
  deliveryCount    Int?
  deliveryEarnings Float?
  status           String    @default("draft")
  createdAt        DateTime  @default(now())
}

// ═══════════════════════════════════════
// NOTIFICATIONS — with locationId
// ═══════════════════════════════════════

model Notification {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  type       String
  title      String
  message    String
  read       Boolean   @default(false)
  link       String?
  createdAt  DateTime  @default(now())
}

// ═══════════════════════════════════════
// SETTINGS (global + per-location)
// ═══════════════════════════════════════

model Setting {
  key   String @id
  value String
}

// ═══════════════════════════════════════
// AUDIT TRAIL — tracks all changes
// ═══════════════════════════════════════

model AuditLog {
  id         String    @id @default(cuid())
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  action     String    // create, update, delete
  entity     String    // Order, Employee, MenuItem, etc.
  entityId   String
  changes    String    @default("{}") // JSON of old → new values
  ip         String?
  createdAt  DateTime  @default(now())
}

// ═══════════════════════════════════════
// REVIEWS
// ═══════════════════════════════════════

model Review {
  id           String   @id @default(cuid())
  orderId      String
  customerName String
  customerPhone String
  rating       Int      // 1-5
  comment      String   @default("")
  reply        String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ═══════════════════════════════════════
// REFERRALS
// ═══════════════════════════════════════

model Referral {
  id            String    @id @default(cuid())
  referrerPhone String
  referrerName  String
  code          String    @unique
  usedBy        String?
  usedAt        DateTime?
  rewardGiven   Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

// ═══════════════════════════════════════
// ORDER CHANNELS (3rd-party platforms)
// ═══════════════════════════════════════

model OrderChannel {
  id         String  @id @default(cuid())
  name       String  // uber_eats, deliveroo, just_eat, website, phone
  active     Boolean @default(true)
  apiKey     String?
  webhookUrl String?
  commission Float   @default(0)
}

// ═══════════════════════════════════════
// DIGITAL SIGNAGE — Multi-site display system
// ═══════════════════════════════════════

model SignageScreen {
  id          String    @id @default(cuid())
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id])
  name        String    // "Écran comptoir 1"
  orientation String    @default("landscape") // landscape | portrait
  resolution  String    @default("1920x1080")
  status      String    @default("draft") // draft | active | offline
  code        String    @unique // 8-char unique code for player connection
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  schedules SignageSchedule[]
}

model SignageContent {
  id          String   @id @default(cuid())
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])
  name        String   // "Menu du midi", "Promo été"
  type        String   // menu | text | image | video | mixed
  duration    Int      @default(10) // seconds
  configJson  String   @default("{}") // type-specific config as JSON
  status      String   @default("draft") // draft | published
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  playlistItems SignagePlaylistItem[]
}

model SignagePlaylist {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  name       String   // "Playlist matin", "Soirée"
  loop       Boolean  @default(true)
  status     String   @default("draft") // draft | published
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items     SignagePlaylistItem[]
  schedules SignageSchedule[]
}

model SignagePlaylistItem {
  id               String          @id @default(cuid())
  playlistId       String
  playlist         SignagePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  contentId        String
  content          SignageContent  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  order            Int
  durationOverride Int?            // null = use content.duration

  @@unique([playlistId, order])
}

model SignageSchedule {
  id         String          @id @default(cuid())
  screenId   String
  screen     SignageScreen   @relation(fields: [screenId], references: [id], onDelete: Cascade)
  playlistId String
  playlist   SignagePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  daysOfWeek String          @default("0,1,2,3,4,5,6") // comma-separated day numbers
  startTime  String          @default("00:00") // HH:mm
  endTime    String          @default("23:59")
  startDate  String?         // YYYY-MM-DD, null = no start limit
  endDate    String?
  priority   Int             @default(0) // higher = takes precedence
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
}

model SignageMedia {
  id           String   @id @default(cuid())
  locationId   String
  location     Location @relation(fields: [locationId], references: [id])
  name         String   // original filename or user-given name
  type         String   // image | video
  url          String   // Cloudinary URL
  thumbnailUrl String?  // Cloudinary thumbnail (for videos)
  publicId     String   // Cloudinary public_id for deletion
  format       String   // jpg, png, mp4, etc.
  width        Int?
  height       Int?
  bytes        Int?     // file size in bytes
  duration     Float?   // video duration in seconds
  folder       String   @default("") // user folder/tag
  createdAt    DateTime @default(now())
}
