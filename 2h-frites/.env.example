# PostgreSQL connection string (Neon, Supabase, or any PG host)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth token signing secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AUTH_SECRET="change-me-to-a-random-secret"

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=""
