# ─── Required everywhere ────────────────────────────────────────────

# PostgreSQL connection string
# obtenir via: console Neon (neon.tech) → Dashboard → Connection Details → Connection string (pooled)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth token signing secret (min 32 chars)
# obtenir via: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-random-secret-of-at-least-32-chars"

# Cron trigger auth (min 16 chars) — protects /api/cron/* endpoints
# obtenir via: openssl rand -hex 16
CRON_SECRET="change-me-cron-secret-16-chars-min"

# Kiosk authentication key (min 16 chars) — shared with kiosk devices
# obtenir via: openssl rand -hex 16
KIOSK_API_KEY="change-me-kiosk-api-key-16-chars-min"

# Base domain — used for cookie scope and tenant resolution
# obtenir via: votre domaine racine (ex: brizoapp.com)
APP_DOMAIN="brizoapp.com"
NEXT_PUBLIC_APP_DOMAIN="brizoapp.com"


# ─── Required in production, optional in dev ────────────────────────

# Stripe
# obtenir via: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=""
# obtenir via: dashboard.stripe.com → Developers → Webhooks → votre endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=""
# obtenir via: dashboard.stripe.com → Products → chaque prix (price_XXX)
STRIPE_PRICE_BASE=""
STRIPE_PRICE_WEB=""
STRIPE_PRICE_KIOSK=""
STRIPE_PRICE_KDS=""
STRIPE_PRICE_ANALYTICS=""
STRIPE_PRICE_MULTIUSERS=""

# Resend (emails transactionnels)
# obtenir via: resend.com → API Keys
RESEND_API_KEY=""

# Identité légale Brizo — affichée dans les emails transactionnels
BRIZO_SUPPORT_EMAIL="support@brizoapp.com"
BRIZO_LEGAL_ADDRESS="BrizoApp SAS — 123 rue Exemple — 1000 Bruxelles"


# ─── Optional ───────────────────────────────────────────────────────

# Sentry (error reporting) — client-side DSN
# obtenir via: sentry.io → Settings → Projects → votre projet → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=""

# Vidéo de démo injectée dans la landing (iframe src)
# obtenir via: URL Loom, YouTube embed, etc.
NEXT_PUBLIC_DEMO_VIDEO_URL=""

# Gemini (extraction OCR de factures d'achat) — non critique
# obtenir via: aistudio.google.com → Get API key
GEMINI_API_KEY=""

# Cloudinary (uploads images: logos, photos produits, signage)
# obtenir via: cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""


# ─── Test DB (isolation from prod) ──────────────────────────────────

# Neon branch 'test' — never main. jest.setup.ts swaps DATABASE_URL to this
# value before tests run. env.ts refuses to boot in NODE_ENV=test if
# DATABASE_URL still points at the main prod branch.
# obtenir via: console Neon > Branches > test > Connection string
DATABASE_URL_TEST=""
